# Canvas iCal Feed
# Canvas → Calendar → Calendar Feed URL
CANVAS_ICAL_URL=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_REFRESH_TOKEN=
TARGET_CALENDAR_ID=primary

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenClaw message routing
OPENCLAW_CHANNEL=discord
OPENCLAW_TARGET=
OPENCLAW_ACCOUNT=
OPENCLAW_SKILL_SECRET=
# Optional: daily digest duplicate delivery to macOS Messages (iMessage)
IMESSAGE_TARGET=

# App config
TIMEZONE=America/Los_Angeles
DIGEST_SCHEDULE_CRON=0 8 * * *
HEARTBEAT_INTERVAL_MINUTES=30
