{
  "name": "college-manager",
  "version": "1.0.0",
  "description": "Proactive academic assistant for Canvas and Google Calendar.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "google:token": "tsx scripts/getRefreshToken.ts",
    "heartbeat": "node dist/index.js",
    "poll": "tsx scripts/poll.ts",
    "sync:calendar": "tsx scripts/syncCalendar.ts",
    "smoke": "npm run typecheck && npm test -- --run && npm run heartbeat",
    "syllabus:extract": "tsx scripts/extractSyllabus.ts",
    "syllabus:enrich": "tsx scripts/enrichFromSyllabus.ts",
    "dashboard": "tsx src/dashboardServer.ts",
    "start:ui": "node scripts/checkNodeVersion.js && tsx src/server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-ical": "^0.18.0",
    "openai": "^4.47.0",
    "pdf-parse": "^1.1.1",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
